{
  "name": "claw-migrate",
  "version": "2.7.5",
  "description": "OpenClaw workspace backup & restore tool - simple, safe, controlled",
  "main": "src/index.js",
  "bin": {
    "claw-migrate": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "setup": "node src/index.js --setup",
    "backup": "node src/index.js --backup",
    "restore": "node src/index.js --restore",
    "restore:ai": "node src/index.js --restore",
    "config": "node src/index.js --config",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:ai": "vitest run tests/unit/restore-ai.test.js",
    "lint": "eslint src/ 2>/dev/null || true",
    "lint:fix": "eslint src/ tests/ --fix"
  },
  "keywords": [
    "openclaw",
    "backup",
    "restore",
    "migration",
    "github"
  ],
  "author": "Han Xueyuan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hanxueyuan/claw-migrate"
  },
  "devDependencies": {
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "displayName": "claw-migrate"
}
