    "lint": "node -c src/*.js && echo '✓ JavaScript syntax OK'",
    "build": "echo 'No build step required (pure JS)'",
    "clean": "rm -rf node_modules/ *.log"
  },
  "keywords": [
    "openclaw",
    "migration",
    "github",
    "configuration",
    "sync"
  ],
