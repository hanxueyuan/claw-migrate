  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hanxueyuan/claw-migrate.git"
  },
  "bugs": {
    "url": "https://github.com/hanxueyuan/claw-migrate/issues"
  },
  "homepage": "https://github.com/hanxueyuan/claw-migrate#readme"
